# Supabase (project: imam-agent-studio)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_PUBLISHABLE_OR_ANON_KEY"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# NVIDIA_API_KEY: Required for NVIDIA API inference
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"

# GOOGLE_PLACES_API_KEY: Required for Client Hunt Engine
GOOGLE_PLACES_API_KEY="MY_GOOGLE_PLACES_API_KEY"
